// यह नया फ़ंक्शन सब-ऐप्स (Google Pay, Paytm आदि) को चुनने में मदद करेगा बिना तुरंत पेमेंट ट्रिगर किए
function selectSubApp(appName) {
  SELECTED_SUB_APP = appName;
  renderPayment();
}

// पुराने selectPayMethod को भी रिसेट करने के लिए अपडेट करें ताकि टैब बदलने पर पुराना चयन मिट जाए
function selectPayMethod(method){
    SELECTED_SUB_APP = ''; // Reset app selection inside tabs
    if(method==="qr"){
        QR_LOADING=true;
        PAYMENT_METHOD="";
        renderPayment();
        setTimeout(()=>{
            QR_LOADING=false;
            PAYMENT_METHOD="qr";
            renderPayment();
        },3000);
        return;
    }
    PAYMENT_METHOD=method;
    renderPayment();
}

let PAYMENT_METHOD=''; // default
let QR_LOADING = false;
// सबसे नीचे के मुख्य "Continue / आगे बढ़ें" बटन के क्लिक लॉजिक को भी सिंक किया
function proceedPay() {
