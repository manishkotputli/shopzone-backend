<%- include('../partials/header') %>

<div class="page-wrap">
  <!-- 3-step progress bar -->
  <div class="checkout-steps" id="checkoutSteps"></div>

  <div id="stepContent"></div>
</div>

<style>
  .progress{
    height:8px;
    background:#eee;
    border-radius:20px;
    overflow:hidden;
    margin-top:20px;
}

.progress-fill{
    width:0%;
    height:100%;
    background:linear-gradient(90deg,#ff9900,#ffc107);
    transition:width 1s linear;
}
.stdone::before{
    content:"✔";
    display:inline-flex;
    justify-content:center;
    align-items:center;
    width:20px;
    height:20px;
    border-radius:50%;
    background:#28a745;
    color:#fff;
    margin-right:8px;
    animation:pop .35s;
}

@keyframes pop{
    0%{transform:scale(0);}
    70%{transform:scale(1.2);}
    100%{transform:scale(1);}
}
.loader{
    box-shadow:0 0 25px rgba(255,153,0,.45);
}

  #paymentProcessing{
    position:fixed;
    inset:0;
    background:rgba(255,255,255,.96);
    display:flex;
    justify-content:center;
    align-items:center;
    z-index:999999;
}

.payment-processing-box{
    width:420px;
    max-width:95%;
    background:#fff;
    padding:30px;
    border-radius:10px;
    text-align:center;
    box-shadow:0 10px 40px rgba(0,0,0,.15);
}

.loader{
    width:70px;
    height:70px;
    border:6px solid #eee;
    border-top:6px solid #ff9900;
    border-radius:50%;
    animation:spin 1s linear infinite;
    margin:auto;
}

@keyframes spin{
    to{
        transform:rotate(360deg);
    }
}

.processing-steps{
    margin-top:25px;
    text-align:left;
    font-size:14px;
    line-height:2;
}
.processing-steps div{
    opacity:.35;
    transform:translateX(-15px);
    transition:.45s ease;
}

.processing-steps div.active{
    opacity:1;
    transform:translateX(0);
    color:#ff9900;
    font-weight:600;
}

.processing-steps div.done{
    opacity:1;
    color:#28a745;
    font-weight:600;
}
.processing-steps div.fail{
    opacity:1;
    transform:translateX(0);
    color:#c62828;      /* red */
    font-weight:600;
}
</style>
<div id="paymentProcessing" style="display:none;">
  <div class="payment-processing-box">
    <div class="loader"></div>

    <h2 id="processingTitle">Verifying Payment...</h2>

    <p id="processingMsg">
      Please do not close this page.<br>
      We are securely verifying your payment.
    </p>

    <div class="processing-steps">
      <div id="s1">✓ Payment request received</div>
      <div id="s2">⏳ Checking payment status...</div>
      <div id="s3">Waiting for bank confirmation...</div>
      <div id="s4" class=" fail">Finalizing your order...</div>
    </div>

    <div style="margin-top:18px;font-size:13px;">
      Estimated time: <span id="countdown">50</span>s
      
    </div>
    <div class="progress">
    <div class="progress-fill" id="progressFill"></div>
</div>
  </div>
</div>

<%- include('../partials/footer') %>

<script>

  let qrInterval;

function startQrTimer(){

    clearInterval(qrInterval);

    let sec=180;

    const timer=document.getElementById("qrTimer");
    const img=document.getElementById("upiQR");
    const btn=document.getElementById("regenQR");

    if(!timer || !img) return;

    img.style.filter="blur(0px)";
    btn.style.display="none";

    qrInterval=setInterval(()=>{

        sec--;

        const m=Math.floor(sec/60);
        const s=sec%60;

        timer.innerHTML=
        String(m).padStart(2,'0')+
        ":"+
        String(s).padStart(2,'0');

        if(sec<=0){

            clearInterval(qrInterval);

            img.style.filter="blur(8px)";
            timer.innerHTML="QR Expired";

            btn.style.display="inline-block";
        }

    },1000);

}
  const STEP_KEY = "checkoutStep";
let STEP = 1; // 1=Address 2=Payment 3=Confirm
let ADDRESS_DATA = {};
let SITE_CFG = {};

const STEPS_EN = ['Address','Payment','Order Confirm'];
const STEPS_HI = ['पता','भुगतान','ऑर्डर कन्फर्म करें'];

function renderSteps(active){
  const isHi=getLang()==='hi';
  const labels=isHi?STEPS_HI:STEPS_EN;
  let html='';
  labels.forEach((lbl,i)=>{
    const n=i+1;
    const state = n<active?'done':n===active?'active':'pending';
    html+=`<div class="step-item">
      <div class="step-circle ${state}">${state==='done'?'✓':n}</div>
      <div class="step-lbl ${state}">${lbl}</div>
    </div>`;
    if(i<labels.length-1){
      html+=`<div class="step-connector ${n<active?'done':''}"></div>`;
    }
  });
  document.getElementById('checkoutSteps').innerHTML=html;
}

/* ══════════════ STEP 1 — ADDRESS ══════════════ */
