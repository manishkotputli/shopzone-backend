/* Forcefully Launch Specific App via Correct Android Intent Formats */
function launchSpecificUpi(app = "") {

    const cfg = SITE_CFG;

    if (!cfg.upi_id) {
        showToast("UPI ID not configured");
        return;
    }

    let total = Number(localStorage.getItem("retryPaymentAmount") || 0);

    if (!total) {

        let cart = JSON.parse(localStorage.getItem("cart") || "[]");

        if (cart.length === 0) {
            cart = JSON.parse(localStorage.getItem("retryPaymentCart") || "[]");
        }

        total = cart.reduce((sum, item) =>
            sum + Number(item.price) * Number(item.qty), 0);
    }

    const orderId = "ORD" + Date.now();

    const params =
        "pa=" + encodeURIComponent(cfg.upi_id) +
        "&pn=" + encodeURIComponent(cfg.upi_name || "ShopZone") +
        "&tr=" + encodeURIComponent(orderId) +
        "&tn=" + encodeURIComponent("Order Payment") +
        "&am=" + total.toFixed(2) +
        "&cu=INR";

    switch(app){

        case "PhonePe":

            window.location.href =
            "phonepe://pay?" + params;

            break;


        case "Google Pay":

            window.location.href =
            "tez://upi/pay?" + params;

            break;


        case "Paytm":

            window.location.href =
            "paytmmp://pay?" + params;

            break;


        case "BHIM":

            window.location.href =
            "bhim://upi/pay?" + params;

            break;


        default:

            window.location.href =
            "upi://pay?" + params;

            break;
    }

    simulatePayment("UPI");
}
