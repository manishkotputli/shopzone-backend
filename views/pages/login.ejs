<%- include('../partials/header') %>

<style>
/* ============ Amazon-style Auth Layout ============ */
.auth-container {
  max-width: 450px;
  margin: 0 auto;
  padding: 20px 18px;
  background: #fff;
  font-family: "Amazon Ember", Arial, sans-serif;
  color: #0f1111;
}

.auth-header-title {
  font-size: 22px;
  font-weight: 500;
  margin-top: 10px;
  margin-bottom: 18px;
  line-height: 1.2;
}

.auth-form-group {
  margin-bottom: 14px;
}

.auth-form-group label {
  display: block;
  font-size: 13px;
  font-weight: 700;
  padding-left: 2px;
  margin-bottom: 5px;
}

.auth-form-group input {
  width: 100%;
  height: 31px;
  padding: 3px 7px;
  line-height: normal;
  border: 1px solid #a6a6a6;
  border-top-color: #949494;
  border-radius: 3px;
  box-shadow: 0 1px 0 rgba(255,255,255,.5), 0 1px 0 rgba(0,0,0,.07) inset;
  outline: 0;
  box-sizing: border-box;
  font-size: 13px;
}

.auth-form-group input:focus {
  border-color: #e77600;
  box-shadow: 0 0 3px rgba(228,121,17,.5);
}

/* Amazon Signature Yellow Button */
.amazon-btn-primary {
  width: 100%;
  height: 31px;
  background: #f7ca00;
  border: 1px solid #f2c200;
  border-radius: 8px;
  font-size: 13px;
  color: #0f1111;
  cursor: pointer;
  box-shadow: 0 2px 5px rgba(213,217,217,.5);
  transition: background 0.1s ease;
  margin-top: 6px;
  margin-bottom: 22px;
}

.amazon-btn-primary:hover {
  background: #f5b800;
  border-color: #e6ac00;
}

/* Legal text */
.auth-legal-text {
  font-size: 12px;
  line-height: 1.5;
  color: #111;
  margin-bottom: 26px;
}

.auth-link-style {
  color: #007185;
  text-decoration: none;
}

.auth-link-style:hover {
  color: #c45500;
  text-decoration: underline;
}

/* Business Section */
.auth-business-section {
  border-top: 1px solid #e7e7e7;
  padding-top: 16px;
  margin-top: 20px;
}

.auth-business-title {
  font-size: 13px;
  font-weight: 700;
  margin-bottom: 4px;
}

.auth-business-link {
  font-size: 13px;
}

/* OTP Block Styling */
.otp-demo-alert {
  background: #fff3cd;
  border: 1px solid #f59e0b;
  border-radius: 6px;
  padding: 10px;
  margin-bottom: 14px;
  font-size: 13px;
  text-align: center;
}
</style>

<div class="auth-container">
  <h1 class="auth-header-title" id="authTitle">
    साइन इन करें या अकाउंट बनाएं
  </h1>

  <div class="auth-form-group">
    <label id="inputLabel">मोबाइल नंबर या ईमेल एंटर करें</label>
    <input type="text" id="loginIdentifier" autofocus>
  </div>

  <button class="amazon-btn-primary" onclick="startLogin()" id="btnContinue">
    जारी रखें
  </button>

  <div class="auth-legal-text" id="legalText">
    जारी रखकर, आप ShopZone की <a href="#" class="auth-link-style">इस्तेमाल की शर्तें</a> और <a href="#" class="auth-link-style">गोपनीयता सूचना</a> के लिए सहमति देते हैं.
  </div>

  <div id="otpSection" style="display:none;">
    <div id="otpDemo" class="otp-demo-alert"></div>
    <div class="auth-form-group">
      <label id="otpLabel">OTP दर्ज करें</label>
      <input type="text" id="loginOtp" maxlength="6" style="letter-spacing:6px; text-align:center; font-size:18px; height: 38px;">
    </div>
    <button class="amazon-btn-primary" onclick="verifyLogin()" id="btnVerify" style="background:#ffa41c; border-color:#ff8f00;">
      सत्यापित करें और लॉग इन करें
    </button>
  </div>

  <div class="auth-business-section">
    <div class="auth-business-title" id="bizTitle">काम के लिए खरीदना?</div>
    <div class="auth-business-link">
      <a href="#" class="auth-link-style" id="bizLink">फ्री बिज़नेस अकाउंट बनाएं</a>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>

<script>
// भाषा के अनुसार टेक्स्ट अपडेट करने का लॉजिक (Dual-language friendly)
function applyLocalization() {
  const isHi = getLang() === 'hi';
  
  if (!isHi) {
    document.getElementById('authTitle').textContent = "Sign in or create account";
    document.getElementById('inputLabel').textContent = "Enter mobile number or email";
    document.getElementById('btnContinue').textContent = "Continue";
    document.getElementById('legalText').innerHTML = `By continuing, you agree to ShopZone's <a href="#" class="auth-link-style">Conditions of Use</a> and <a href="#" class="auth-link-style">Privacy Notice</a>.`;
    document.getElementById('otpLabel').textContent = "Enter OTP";
    document.getElementById('btnVerify').textContent = "Verify & Login";
    document.getElementById('bizTitle').textContent = "Buying for work?";
    document.getElementById('bizLink').textContent = "Create a free business account";
  }
}

function startLogin() {
  const inputVal = document.getElementById('loginIdentifier').value.trim();
  const isHi = getLang() === 'hi';
  
  if (!inputVal) {
    alert(isHi ? 'कृपया मोबाइल नंबर या ईमेल दर्ज करें' : 'Please enter mobile number or email');
    return;
  }
  
  // पुराना OTP जेनरेशन लॉजिक सुरक्षित रखते हुए
  const cleanInput = inputVal.replace(/\D/g,'') || "1234567890";
  const otp = generateOTP(cleanInput); 
  
  document.getElementById('otpSection').style.display = 'block';
  document.getElementById('otpDemo').innerHTML = `📱 <strong>${isHi ? 'डेमो OTP' : 'Demo OTP'}:</strong> <span style="font-size:20px; font-weight:800; letter-spacing:4px;">${otp}</span>`;
  
  // स्क्रॉल को OTP सेक्शन पर ले जाने के लिए
  document.getElementById('otpSection').scrollIntoView({ behavior: 'smooth' });
}

function verifyLogin() {
  const otp = document.getElementById('loginOtp').value.trim();
  const inputVal = document.getElementById('loginIdentifier').value.trim();
  const isHi = getLang() === 'hi';
  
  if (!verifyOTP(otp)) {
    alert(isHi ? 'गलत OTP' : 'Invalid OTP');
    return;
  }
  
  loginUser(inputVal, inputVal);
  showToast(isHi ? '✓ लॉगिन सफल!' : '✓ Login successful!');
  setTimeout(() => window.location.href = '/', 800);
}

// पेज लोड होने पर भाषा सेट करें
applyLocalization();
</script>