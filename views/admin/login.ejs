<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ShopZone Admin Login</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/images/logo.png">
  <style>
    body { background: #131921; display: flex; align-items: center; justify-content: center; min-height: 100vh; }
    .admin-login-box { background: #fff; border-radius: 10px; padding: 40px; width: 100%; max-width: 380px; box-shadow: 0 8px 32px rgba(0,0,0,.4); }
    .admin-logo { text-align: center; margin-bottom: 24px; }
    .admin-logo img { height: 50px; margin: 0 auto 8px; }
    .admin-logo .logo-name { color: #131921; font-size: 22px; font-weight: 800; }
    .admin-logo .logo-name span { color: #f90; }
    .admin-badge { background: #f90; color: #131921; font-size: 11px; font-weight: 700; padding: 2px 10px; border-radius: 20px; display: inline-block; margin-bottom: 20px; }
    .admin-title { font-size: 20px; font-weight: 700; margin-bottom: 20px; text-align: center; }
    .err-msg { background: #fff5f5; border: 1px solid #f87171; color: #b91c1c; padding: 10px 14px; border-radius: 6px; font-size: 13px; margin-bottom: 14px; }
  </style>
</head>
<body>
<div class="admin-login-box">
  <div class="admin-logo">
    <img src="/images/logo.png" alt="ShopZone">
    <div class="logo-name">Shop<span>Zone</span></div>
    <div class="admin-badge">🔐 Admin Panel</div>
  </div>
  <div class="admin-title">Admin Login</div>
  <% if(locals.error){ %><div class="err-msg">❌ <%=error%></div><% } %>
  <form method="POST" action="/admin/login">
    <div class="form-group">
      <label>Admin Username</label>
      <input type="text" name="username" placeholder="admin" required autofocus>
    </div>
    <div class="form-group">
      <label>Password</label>
      <input type="password" name="password" placeholder="••••••••" required>
    </div>
    <button type="submit" class="submit-btn" style="margin-top:6px;">Login to Admin Panel</button>
  </form>
  <div style="text-align:center;margin-top:16px;font-size:12px;color:#565959;">
    Default: admin / shopzone123
  </div>
</div>
</body>
</html>
