function filterReviews() {
  const s = (document.getElementById('revSrch')?.value || '').toLowerCase();
  const pf = document.getElementById('revProdF')?.value || '';
  const rf = document.getElementById('revRatingF')?.value || '';
  let revs = ALL_REVS;
  if (s) revs = revs.filter(r => r.reviewer_name?.toLowerCase().includes(s) || r.title?.toLowerCase().includes(s));
  if (pf === 'global') revs = revs.filter(r => !r.product_id);
  else if (pf) revs = revs.filter(r => String(r.product_id) === pf);
  if (rf) revs = revs.filter(r => String(r.rating) === rf);
  document.getElementById('revCountLbl').textContent = `(${revs.length})`;
  document.getElementById('reviewTb').innerHTML = revs.length ? revs.map(rv=>`<tr>
    <td>#${rv.id}</td>
    <td>${rv.product_id?`<span class="pill pill-blue">#${rv.product_id}</span>`:'<span class="pill pill-purple">Global</span>'}</td>
    <td><strong>${rv.reviewer_name}</strong>${rv.reviewer_city?`<br><span style="font-size:10px;color:#565959;">📍${rv.reviewer_city}</span>`:''}</td>
    <td><span style="color:#f0a500;">${'★'.repeat(rv.rating||5)}</span></td>
    <td style="max-width:140px;font-size:11px;">${rv.title||'-'}</td>
    <td style="max-width:180px;font-size:11px;color:#565959;">${(rv.body||'').substring(0,60)}${rv.body?.length>60?'...':''}</td>
    <td style="white-space:nowrap;">${rv.review_date||'-'}</td>
    <td>${rv.verified?'<span class="pill pill-green">✓ Verified</span>':'—'}</td>
    <td>${rv.is_active?'<span class="pill pill-green">Active</span>':'<span class="pill pill-gray">Hidden</span>'}</td>
    <td style="white-space:nowrap;">
      <button class="btn btn-edit btn-sm" onclick="editRev(${rv.id})">✏️</button>
      <button class="btn btn-del btn-sm" onclick="deleteRev(${rv.id},'${(rv.reviewer_name||'').replace(/'/g,"\\'")}')">🗑</button>
    </td>
  </tr>`).join('') : '<tr class="empty-row"><td colspan="10">No reviews found</td></tr>';
}

const RATING_LABELS = {1:'⭐ Poor',2:'⭐⭐ Below Average',3:'⭐⭐⭐ Average',4:'⭐⭐⭐⭐ Good!',5:'⭐⭐⭐⭐⭐ Excellent!'};
function setRating(n){
  RATING_VAL=n;
  const el = document.getElementById('revRating'); if(el) el.value=n;
  document.querySelectorAll('.star-r').forEach((s,i)=>s.classList.toggle('on',i<n));
  const rl = document.getElementById('ratingText'); if(rl) rl.textContent=RATING_LABELS[n]||'';
}

function editRev(id){
  const rv=ALL_REVS.find(r=>r.id===id); if(!rv) return;
  document.getElementById('revEditId').value=rv.id;
  document.getElementById('revProdId').value=rv.product_id||'';
  document.getElementById('revName').value=rv.reviewer_name||'';
  document.getElementById('revCity').value=rv.reviewer_city||'';
  document.getElementById('revDate').value=rv.review_date||'';
  document.getElementById('revTitle').value=rv.title||'';
  document.getElementById('revBody').value=rv.body||'';
  document.getElementById('revHelpful').value=rv.helpful_count||0;
  document.getElementById('revVerified').value=String(rv.verified);
  document.getElementById('revActive').value=String(rv.is_active);
  setRating(rv.rating||5);
  document.getElementById('revFormTitle').textContent='✏️ Edit Review #'+id;
  window.scrollTo({top:0,behavior:'smooth'});
}

async function saveReview(){
  const eid=document.getElementById('revEditId').value;
  const body={
    product_id:document.getElementById('revProdId').value||null,
    reviewer_name:document.getElementById('revName').value.trim(),
    reviewer_city:document.getElementById('revCity').value.trim(),
    review_date:document.getElementById('revDate').value,
    rating:document.getElementById('revRating').value,
    title:document.getElementById('revTitle').value.trim(),
    body:document.getElementById('revBody').value.trim(),
    helpful_count:document.getElementById('revHelpful').value||0,
    verified:document.getElementById('revVerified').value,
    is_active:document.getElementById('revActive').value,
  };
  if(!body.reviewer_name||!body.body){ showMsg('revMsg','❌ Reviewer name and review body are required!','error'); return; }
  const url=eid?'/admin/api/reviews/'+eid:'/admin/api/reviews';
  const d=await api(url,{method:eid?'PUT':'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
  if(d.success){
    showMsg('revMsg',eid?'✅ Review updated!':'✅ Review added!','success');
    resetReviewForm();
    const rd=await api('/admin/api/reviews'); ALL_REVS=rd.reviews||[];
    document.getElementById('sb-rev-count').textContent=ALL_REVS.length;
    filterReviews();
  } else { showMsg('revMsg','❌ '+d.error,'error'); }
}
async function deleteRev(id,name){
  confirmDelete(`Delete review by "${name}"?`, async()=>{
    const d=await api('/admin/api/reviews/'+id,{method:'DELETE'});
    if(d.success){ ALL_REVS=ALL_REVS.filter(r=>r.id!==id); document.getElementById('sb-rev-count').textContent=ALL_REVS.length; filterReviews(); }
  });
}
function resetReviewForm(){
  document.getElementById('revEditId').value='';
  document.getElementById('revFormTitle').textContent='➕ Add Review';
  ['revProdId','revName','revCity','revTitle','revBody'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';});
  document.getElementById('revHelpful').value=0;
  document.getElementById('revDate').value=new Date().toISOString().split('T')[0];
  document.getElementById('revVerified').value='true';
  document.getElementById('revActive').value='true';
  setRating(5);
}

