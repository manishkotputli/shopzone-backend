function esc(v) { return (v||'').toString().replace(/"/g,'&quot;').replace(/</g,'&lt;'); }

function addDRow(listId, ph, val = '') {
  const d = document.createElement('div'); d.className = 'dli';
  d.innerHTML = `<input type="text" placeholder="${ph}" value="${val.replace(/"/g,'&quot;')}"><button type="button" class="rm-btn" onclick="this.parentElement.remove()">✕</button>`;
  document.getElementById(listId).appendChild(d);
}
function addSpecRow(k = '', v = '') {
  const d = document.createElement('div'); d.className = 'dli';
  d.innerHTML = `<input type="text" placeholder="Key e.g. RAM" value="${k.replace(/"/g,'&quot;')}" style="max-width:160px;"><input type="text" placeholder="Value e.g. 8GB" value="${v.replace(/"/g,'&quot;')}"><button type="button" class="rm-btn" onclick="this.parentElement.remove()">✕</button>`;
  document.getElementById('specList').appendChild(d);
}
function addVariantRow(type='', value='', pm=0, stock=0, images=[]) {

    if (typeof images === "string") {
        try {
            images = JSON.parse(images);
        } catch (e) {
            images = [];
        }
    }

    const tr = document.createElement("tr");

    tr.innerHTML = `
        <td><input type="text" list="varTypeDL" value="${type}" style="width:110px"></td>

        <td><input type="text" value="${value}" style="width:100px"></td>

        <td><input type="number" value="${pm}" style="width:80px"></td>

        <td><input type="number" value="${stock}" style="width:70px"></td>

        <td><input type="number" value="0" style="width:50px"></td>

        <td>

            <input
                type="file"
                multiple
                accept="image/*"
                onchange="uploadVariantImages(this)">

            <input
                type="hidden"
                class="variant-images"
                value='${JSON.stringify(images)}'>

            <div class="variant-preview">

                ${images.map(img => `
                    <img src="${img}"
                    style="
                        width:50px;
                        height:50px;
                        object-fit:cover;
                        margin:3px;
                        border-radius:5px;
                    ">
                `).join("")}

            </div>

        </td>

        <td>
            <button class="rm-btn"
                onclick="this.closest('tr').remove()">✕</button>
        </td>
    `;

    document.getElementById("variantTb").appendChild(tr);
}
function getDList(id) { return [...document.querySelectorAll(`#${id} input`)].map(i=>i.value.trim()).filter(Boolean); }
function getSpecs() {
  const rows = document.querySelectorAll('#specList .dli'), o = {};
  rows.forEach(d => { const is = d.querySelectorAll('input'); const k = is[0].value.trim(), v = is[1].value.trim(); if(k&&v) o[k]=v; });
  return o;
}
function getVariants() {

    return [...document.querySelectorAll("#variantTb tr")]
    .map((tr, i) => {

        const ins = tr.querySelectorAll(
            "input[type=text],input[type=number]"
        );

        let images = [];

        try{
            images = JSON.parse(
                tr.querySelector(".variant-images")?.value || "[]"
            );
        }catch(e){
            images = [];
        }

        return {

            variant_type: ins[0].value.trim(),

            variant_value: ins[1].value.trim(),

            price_modifier: parseFloat(ins[2].value) || 0,

            stock: parseInt(ins[3].value) || 0,

            images: images,

            sort_order: i

        };

    })
    .filter(v => v.variant_type && v.variant_value);

}
function prevImg(input, previewId) {
  const preview = document.getElementById(previewId);
  preview.innerHTML = "";
  if (!input.files.length) {
    preview.innerHTML = `<div class="imgprev imgprev-lg"><span>Click to upload</span></div>`;
    return;
  }
  const reader = new FileReader();
  reader.onload = e => {
    preview.innerHTML = `<div class="imgprev imgprev-lg"><img src="${e.target.result}"></div>`;
  };
  reader.readAsDataURL(input.files[0]);
}


function prevMultipleImg(input,id){

    const box=document.getElementById(id);

    box.innerHTML="";

    [...input.files].forEach(file=>{

        const reader=new FileReader();

        reader.onload=function(e){

            box.innerHTML+=`
            <div class="imgprev imgprev-lg">
                <img src="${e.target.result}">
            </div>
            `;

        }

        reader.readAsDataURL(file);

    });

}
async function saveProduct() {
  const eid = document.getElementById('editId').value;
  const name = document.getElementById('pName').value.trim();
  const price = document.getElementById('pPrice').value;
  const cat = document.getElementById('pCat').value.trim();
  if (!name || !price || !cat) {
    showMsg('formMsg', 'Product Name, Price and Category are required!', 'error'); return;
  }

  // Auto-calc discount
  let disc = document.getElementById('pDisc').value;
  const orig = document.getElementById('pOrig').value;
  if (!disc && orig && parseFloat(orig) > parseFloat(price)) {
    disc = Math.round((1 - parseFloat(price)/parseFloat(orig)) * 100);
    document.getElementById('pDisc').value = disc;
  }

  const fd = new FormData();
  const fields = [['name','pName'],['brand','pBrand'],['category','pCat'],['sub_category','pSubCat'],['sku','pSku'],['emoji','pEmoji'],['price','pPrice'],['original_price','pOrig'],['discount_percent','pDisc'],['stock_quantity','pStock'],['rating','pRating'],['review_count','pReviews'],['badge','pBadge'],['is_featured','pFeatured'],['is_active','pActive'],['warranty_months','pWarr'],['weight_grams','pWt'],['country_of_origin','pOrigin'],['seller_name','pSeller'],['tags','pTags'],['description','pDesc']];
  fields.forEach(([k, id]) => { const el = document.getElementById(id); if(el) fd.append(k, el.value); });
  fd.append('highlights', JSON.stringify(getDList('hlList')));
  fd.append('in_box', JSON.stringify(getDList('boxList')));
  fd.append('specifications', JSON.stringify(getSpecs()));

  // const f = document.getElementById('pImg');
  // if (f && f.files[0]) fd.append('image', f.files);

const imgFiles = document.getElementById("pImg").files;
const files=document.getElementById("pImg").files;

for(const file of files){

    fd.append("images",file);

}
  const btn = document.querySelector('[onclick="saveProduct()"]');
  if (btn) { btn.disabled = true; btn.textContent = 'Saving...'; }

  const url = eid ? '/admin/api/products/' + eid : '/admin/api/products';
  const d = await api(url, { method: eid ? 'PUT' : 'POST', body: fd });
for (const pair of fd.entries()) {
    console.log(pair[0], pair[1]);
}

  if (d.success) {
    const pid = d.product.id || eid;
    const vars = getVariants();
   
    await api('/admin/api/products/' + pid + '/variants', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ variants: vars })
    });
    showMsg('formMsg', eid ? '✅ Product updated successfully!' : '✅ Product added successfully!', 'success');
    // Refresh products list
    const pd = await api('/admin/api/products');
    ALL_PRODS = pd.products || [];
    document.getElementById('sb-prod-count').textContent = ALL_PRODS.length;
    await loadAll();
    if (!eid) { renderAddProduct(null); }
    if (btn) { btn.disabled = false; btn.textContent = '💾 ' + (eid ? 'Update Product' : 'Add Product'); }
  } else {
    showMsg('formMsg', '❌ Error: ' + d.error, 'error');
    if (btn) { btn.disabled = false; btn.textContent = '💾 Save'; }
  }
}

