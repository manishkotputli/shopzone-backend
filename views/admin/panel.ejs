<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/dist/tabler-icons.min.css">
<title>ShopZone Admin Panel</title>
<style>
  
/* TD Container for all buttons */
td.action-buttons {
    display: flex;
        margin-top: 63px;
    align-items: center;
    gap: 8px; /* Buttons ke beech ka gap */
}

/* Toggle Switch Base */
.toggle-switch {
    position: relative;
    display: inline-block;
    width: 30px;
    height: 20px;
    cursor: pointer;
    margin: 0; /* Extra margin hatane ke liye */
}

.toggle-switch input {
    display: none;
}

/* The Slider Track */
.toggle-switch .slider {
    position: absolute;
    inset: 0;
    background: #6b7280;
    border-radius: 50px;
    transition: .3s ease;
    box-shadow: inset 0 2px 4px rgba(0,0,0,.2);
}

/* The Slider Knob (Ball) */
.toggle-switch .slider::before {
    content: "";
    position: absolute;
    width: 12px;
    height: 12px;
    left: 4px;
    top: 4px;
    background: #fff;
    border-radius: 50%;
    transition: .3s ease;
    box-shadow: 0 2px 4px rgba(0,0,0,.2);
}

/* Checked State - Background change */
.toggle-switch input:checked + .slider {
    background: #22c55e;
}

/* Checked State - Knob Movement Fixed for 30px width */
.toggle-switch input:checked + .slider::before {
    transform: translateX(10px); /* 24px se badal kar 10px kar diya hai */
}
/* ═══ RESET & BASE ═══ */
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Segoe UI',Arial,sans-serif;background:#eaeded;color:#0f1111;font-size:14px;display:flex;flex-direction:column;min-height:100vh;}
a{text-decoration:none;color:inherit;}
button{font-family:inherit;cursor:pointer;}
input,select,textarea{font-family:inherit;}

/* ═══ TOP HEADER ═══ */
.topbar{background:#131921;color:#fff;height:52px;display:flex;align-items:center;justify-content:space-between;padding:0 20px;position:fixed;top:0;left:0;right:0;z-index:300;}
.topbar-left{display:flex;align-items:center;gap:10px;}
.topbar-logo{font-size:20px;font-weight:900;color:#fff;letter-spacing:-0.5px;}
.topbar-logo span{color:#f90;}
.topbar-badge{background:#f90;color:#131921;font-size:10px;font-weight:800;padding:2px 8px;border-radius:12px;}
.topbar-right{display:flex;align-items:center;gap:12px;}
.topbar-right span{font-size:12px;color:#ccc;}
.btn-logout{background:#dc2626;color:#fff;border:none;padding:5px 14px;border-radius:4px;font-size:12px;font-weight:600;}
.hamburger{background:none;border:none;color:#fff;font-size:22px;display:none;padding:4px;}

/* ═══ BODY LAYOUT: sidebar + main ═══ */
.body-wrap{display:flex;min-height:calc(100vh - 52px);margin-top:52px;}

/* ═══ SIDEBAR ═══ */
.sidebar{width:220px;background:#232f3e;flex-shrink:0;position:fixed;top:52px;left:0;bottom:0;overflow-y:auto;z-index:200;transition:transform .25s;}
.sidebar-section{padding:14px 0 6px;border-bottom:1px solid rgba(255,255,255,.08);}
.sidebar-section:last-child{border-bottom:none;}
.sidebar-section-title{font-size:10px;font-weight:700;color:#8a9bb0;text-transform:uppercase;letter-spacing:1px;padding:0 16px 8px;}
.sidebar-link{display:flex;align-items:center;gap:10px;padding:10px 16px;font-size:13px;color:#d5dbdb;cursor:pointer;border:none;background:none;width:100%;text-align:left;transition:background .15s;}
.sidebar-link:hover{background:rgba(255,255,255,.07);color:#fff;}
.sidebar-link.active{background:#f90;color:#131921;font-weight:700;}
.sidebar-link .icon{font-size:16px;width:22px;text-align:center;flex-shrink:0;}
.sidebar-link .badge-count{margin-left:auto;background:rgba(255,255,255,.15);color:#fff;font-size:10px;font-weight:700;padding:1px 7px;border-radius:10px;}
.sidebar-link.active .badge-count{background:rgba(0,0,0,.2);color:#131921;}
.sidebar-store-info{padding:12px 16px;border-top:1px solid rgba(255,255,255,.08);}
.sidebar-store-info p{font-size:11px;color:#8a9bb0;margin-bottom:2px;}
.sidebar-store-info strong{font-size:12px;color:#d5dbdb;}

/* ═══ MAIN CONTENT ═══ */
.main{margin-left:220px;flex:1;padding:20px;min-width:0;}

/* ═══ OVERLAY (mobile) ═══ */
.overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:199;}

/* ═══ STATS GRID ═══ */
.stats{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:12px;margin-bottom:20px;}
.stat{background:#fff;border-radius:8px;padding:16px;text-align:center;border-left:4px solid #f90;box-shadow:0 2px 8px rgba(0,0,0,.07);}
.stat .n{font-size:28px;font-weight:800;}
.stat .l{font-size:11px;color:#565959;margin-top:3px;}
.stat .sub{font-size:10px;color:#999;margin-top:2px;}

/* ═══ PAGE HEADER ═══ */
.page-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;flex-wrap:wrap;gap:10px;}
.page-header h1{font-size:20px;font-weight:700;}
.breadcrumb{font-size:12px;color:#565959;margin-bottom:16px;}
.breadcrumb span{color:#f90;}

/* ═══ CARD ═══ */
.card{background:#fff;border-radius:8px;padding:20px;margin-bottom:16px;box-shadow:0 2px 8px rgba(0,0,0,.07);}
.card h2{font-size:16px;font-weight:700;margin-bottom:14px;padding-bottom:10px;border-bottom:1.5px solid #f0f0f0;display:flex;align-items:center;gap:8px;}
.card h2 span.sub{font-size:13px;font-weight:400;color:#565959;}

/* ═══ TABLE ═══ */
.tbl-wrap{overflow-x:auto;}
table{width:100%;border-collapse:collapse;}
thead th{background:#131921;color:#fff;padding:10px 12px;text-align:left;font-size:12px;font-weight:600;position:sticky;top:0;}
tbody td{padding:10px 12px;border-bottom:1px solid #f0f0f0;font-size:12px;vertical-align:middle;}
tbody tr:hover td{background:#fafafa;}
tbody tr:last-child td{border-bottom:none;}
.empty-row td{text-align:center;padding:32px;color:#999;}

/* ═══ BUTTONS ═══ */
.btn{display:inline-flex;align-items:center;gap:5px;border:none;border-radius:4px;font-size:12px;font-weight:600;cursor:pointer;padding:5px 12px;transition:opacity .15s;}
.btn:hover{opacity:.88;}
.btn-primary{background:#f90;color:#131921;font-size:13px;padding:9px 18px;border-radius:6px;font-weight:700;}
.btn-secondary{background:#232f3e;color:#fff;font-size:13px;padding:9px 18px;border-radius:6px;}
.btn-edit{background:#007185;color:#fff;}
.btn-del{background:#dc2626;color:#fff;}
.btn-toggle{background:#6c757d;color:#fff;}
.btn-toggle.on{background:#067d62;}
.btn-view{background:#6f42c1;color:#fff;}
.btn-sm{padding:3px 8px;font-size:11px;}
.btn-outline{background:#fff;border:1.5px solid #ddd;color:#333;}
.btn-outline:hover{border-color:#f90;}

/* ═══ FORMS ═══ */
.fg{margin-bottom:12px;}
.fg label{display:block;font-size:12px;font-weight:600;margin-bottom:4px;color:#333;}
.fg .hint{font-size:11px;color:#888;margin-top:3px;}
.fg input,.fg select,.fg textarea{width:100%;padding:9px 11px;border:1.5px solid #ddd;border-radius:4px;font-size:13px;outline:none;transition:border-color .15s;}
.fg input:focus,.fg select:focus,.fg textarea:focus{border-color:#f90;box-shadow:0 0 0 2px rgba(255,153,0,.15);}
.fg input.err,.fg select.err{border-color:#dc2626;}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
.grid3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;}
.full{grid-column:1/-1;}
.form-actions{display:flex;gap:10px;margin-top:18px;padding-top:16px;border-top:1.5px solid #f0f0f0;}

/* ═══ SEARCH BAR ═══ */
.search-bar{display:flex;gap:8px;margin-bottom:14px;flex-wrap:wrap;}
.search-bar input{flex:1;min-width:180px;padding:8px 12px;border:1.5px solid #ddd;border-radius:4px;font-size:13px;outline:none;}
.search-bar input:focus{border-color:#f90;}
.search-bar select{padding:8px 12px;border:1.5px solid #ddd;border-radius:4px;font-size:13px;outline:none;}

/* ═══ PILLS & BADGES ═══ */
.pill{display:inline-block;padding:2px 8px;border-radius:10px;font-size:10px;font-weight:600;}
.pill-blue{background:#e0f0ff;color:#007185;}
.pill-green{background:#e6f9f0;color:#067d62;}
.pill-red{background:#ffe4e4;color:#dc2626;}
.pill-orange{background:#fff3e0;color:#e47911;}
.pill-gray{background:#f0f0f0;color:#565959;}
.pill-purple{background:#f3e8ff;color:#7c3aed;}
.dot{width:8px;height:8px;border-radius:50%;display:inline-block;margin-right:4px;}
.dot-green{background:#067d62;}
.dot-red{background:#dc2626;}
.dot-gray{background:#999;}

/* ═══ MESSAGES ═══ */
.msg{padding:10px 14px;border-radius:4px;font-size:13px;margin-bottom:12px;display:flex;align-items:center;gap:8px;}
.msg-success{background:#d1fae5;border:1px solid #34d399;color:#065f46;}
.msg-error{background:#fee2e2;border:1px solid #f87171;color:#991b1b;}
.msg-info{background:#e0f0ff;border:1px solid #7ec8e3;color:#004b6b;}
.msg-warn{background:#fff3cd;border:1px solid #f59e0b;color:#856404;}

/* ═══ DYNAMIC LIST ROWS ═══ */
.dli{display:flex;gap:6px;margin-bottom:6px;align-items:center;}
.dli input{flex:1;}
.rm-btn{background:#dc2626;color:#fff;border:none;width:26px;height:26px;border-radius:4px;cursor:pointer;flex-shrink:0;font-size:14px;}
.add-row-btn{background:#007185;color:#fff;border:none;padding:5px 13px;border-radius:4px;font-size:12px;cursor:pointer;margin-top:5px;display:inline-flex;align-items:center;gap:4px;}

/* ═══ VARIANTS TABLE ═══ */
.variants-wrap{overflow-x:auto;margin-top:8px;}
.variants-wrap table{min-width:560px;}

/* ═══ IMAGE PREVIEW ═══ */
.imgprev{width:80px;height:80px;border:1.5px dashed #ddd;border-radius:6px;display:flex;align-items:center;justify-content:center;overflow:hidden;background:#f7f7f7;margin-top:6px;cursor:pointer;}
.imgprev img{width:100%;height:100%;object-fit:contain;}
.imgprev-lg{width:130px;height:130px;}
.imgprev span{font-size:10px;color:#999;text-align:center;}

/* ═══ STARS ═══ */
.stars-inp{display:flex;gap:2px;margin-top:4px;}
.star-r{font-size:26px;cursor:pointer;color:#ddd;transition:color .1s;line-height:1;}
.star-r.on,.star-r:hover{color:#f0a500;}

/* ═══ SECTION DIVIDER ═══ */
.section-divider{border:none;border-top:1.5px solid #f0f0f0;margin:18px 0;}
.section-sub-title{font-size:13px;font-weight:700;color:#131921;margin-bottom:12px;display:flex;align-items:center;justify-content:space-between;}

/* ═══ MODAL ═══ */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:500;display:none;align-items:center;justify-content:center;}
.modal-overlay.open{display:flex;}
.modal{background:#fff;border-radius:10px;padding:24px;width:90%;max-width:480px;box-shadow:0 8px 32px rgba(0,0,0,.2);}
.modal h3{font-size:16px;font-weight:700;margin-bottom:14px;padding-bottom:10px;border-bottom:1.5px solid #f0f0f0;}
.modal-actions{display:flex;gap:10px;justify-content:flex-end;margin-top:16px;}

/* ═══ QR PREVIEW ═══ */
.qrprev{width:140px;height:140px;border:2px dashed #ddd;border-radius:8px;display:flex;align-items:center;justify-content:center;overflow:hidden;background:#f7f7f7;margin-bottom:10px;}
.qrprev img{width:100%;height:100%;object-fit:contain;}

/* ═══ TABS (inner) ═══ */
.inner-tabs{display:flex;gap:0;border-bottom:2px solid #f0f0f0;margin-bottom:16px;}
.inner-tab{padding:8px 16px;font-size:13px;font-weight:600;border:none;background:none;color:#565959;cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-2px;}
.inner-tab.active{color:#e47911;border-bottom-color:#e47911;}

/* ═══ RESPONSIVE ═══ */
@media(max-width:768px){
  .sidebar{transform:translateX(-100%);}
  .sidebar.open{transform:translateX(0);}
  .main{margin-left:0;}
  .hamburger{display:block;}
  .grid2,.grid3{grid-template-columns:1fr;}
  .full{grid-column:1;}
  .overlay.open{display:block;}
}
@media(max-width:500px){
  .stats{grid-template-columns:1fr 1fr;}
  .page-header{flex-direction:column;align-items:flex-start;}
}
</style>
</head>
<body>



