// ════════════════════════════════════════════════════════
// SHARED CONFIG SAVE
// ════════════════════════════════════════════════════════
async function saveCfg(keys, msgId) {
  const payload = {};
  keys.forEach(k => { const el = document.getElementById('c_'+k); if(el) payload[k] = el.value; });
  const d = await api('/admin/api/config', {
    method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify(payload)
  });
  if (d.success) {
    Object.assign(CFG, payload);
    // Update store name in topbar
    if (payload.store_name) {
      document.getElementById('topStoreName').textContent = payload.store_name;
      document.getElementById('sbStoreName').textContent = payload.store_name;
    }
    showMsg(msgId, '✅ Settings saved successfully!', 'success');
  } else {
    showMsg(msgId, '❌ Error: ' + d.error, 'error');
  }
}


async function uploadStoreLogo(){

    const file=document.getElementById("storeLogo").files[0];

    if(!file){
        alert("Select logo");
        return;
    }

    const fd=new FormData();
    fd.append("logo",file);

    const res=await fetch("/admin/api/upload-logo", {
        method:"POST",
        body:fd
    });

    const data=await res.json();

    if(data.success){

        CFG.store_logo=data.logo;

        document.getElementById("logoPreview").src=data.logo;

        showMsg("storeMsg","✅ Logo uploaded","success");

    }else{

        showMsg("storeMsg",data.error,"error");

    }

}


