      <i class="ti ti-trash" style="font-size: 14px;"></i>
  </button>
</div>
</td>
    </tr>`;
  }).join('') : '<tr class="empty-row"><td colspan="13">No products found</td></tr>';
}

async function viewProduct(id) {
  const d = await api('/admin/api/products/' + id);
  if (!d.success) return;
  const p = d.product;
  const specs = p.specifications || {};
  document.getElementById('viewModalTitle').textContent = p.name.substring(0,50);
  document.getElementById('viewModalBody').innerHTML = `
    <div style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:12px;">
      <div style="font-size:48px;background:#f7f7f7;width:80px;height:80px;display:flex;align-items:center;justify-content:center;border-radius:6px;">
        ${p.image_url?`<img src="${p.image_url}" style="width:100%;height:100%;object-fit:contain;">`:p.emoji||'📦'}
      </div>
      <div style="flex:1;">
        <div style="margin-bottom:4px;"><strong>Brand:</strong> ${p.brand||'-'}</div>
        <div style="margin-bottom:4px;"><strong>Category:</strong> ${p.category||'-'} ${p.sub_category?`› ${p.sub_category}`:''}</div>
        <div style="margin-bottom:4px;"><strong>SKU:</strong> ${p.sku||'-'}</div>
        <div style="margin-bottom:4px;"><strong>Price:</strong> ₹${parseFloat(p.price).toLocaleString('en-IN')} ${p.original_price?`<s style="color:#999;">₹${parseFloat(p.original_price).toLocaleString('en-IN')}</s>`:''}</div>
        <div><strong>Stock:</strong> <span class="pill ${p.stock_quantity===0?'pill-red':'pill-green'}">${p.stock_quantity}</span></div>
      </div>
    </div>
    ${p.description?`<p style="font-size:12px;color:#333;margin-bottom:10px;line-height:1.6;">${p.description}</p>`:''}
    ${Object.keys(specs).length?`
    <table style="width:100%;font-size:12px;border-collapse:collapse;">
      ${Object.entries(specs).map(([k,v])=>`<tr><td style="background:#f7f7f7;padding:5px 8px;font-weight:600;width:40%;border-bottom:1px solid #eee;">${k}</td><td style="padding:5px 8px;border-bottom:1px solid #eee;">${v}</td></tr>`).join('')}
    </table>`:''}
    ${(p.variants||[]).length?`<div style="margin-top:10px;font-size:12px;"><strong>Variants (${p.variants.length}):</strong> ${p.variants.map(v=>`<span class="pill pill-blue" style="margin:2px;">${v.variant_type}: ${v.variant_value}</span>`).join('')}</div>`:''}
  `;
  openModal('viewModal');
}

async function editProduct(id) {
  const d = await api('/admin/api/products/' + id);
  if (!d.success) return;
  renderAddProduct(d.product);
  navTo('add-product', false);
}

async function toggleActive(id, newState) {
    console.log("ID:", id);
    console.log("newState:", newState, typeof newState);

    const fd = new FormData();
    fd.append("is_active", newState);

    for (const [k, v] of fd.entries()) {
        console.log(k, v);
    }

    const d = await api('/admin/api/products/' + id, {
        method: 'PUT',
        body: fd
    });

    console.log(d);
}


function deleteProduct(id, name) {
  confirmDelete(`Delete product "${name.substring(0,40)}"?`, async () => {
    const d = await api('/admin/api/products/' + id, { method: 'DELETE' });
    if (d.success) {
      ALL_PRODS = ALL_PRODS.filter(p => p.id !== id);
      document.getElementById('sb-prod-count').textContent = ALL_PRODS.length;
      filterTable();
    } else alert('Error: ' + d.error);
  });
}

async function uploadVariantImages(input){

    if(!input.files.length) return;

    const fd=new FormData();

    [...input.files].forEach(file=>{
        fd.append("images",file);
    });

    const d=await api(
        "/admin/api/variants/upload-images",
        {
            method:"POST",
            body:fd
        }
    );

    if(!d.success){
        return alert(d.error);
    }

    const td=input.closest("td");

    td.querySelector(".variant-images").value=
        JSON.stringify(d.images);

    td.querySelector(".variant-preview").innerHTML=
        d.images.map(img=>`
            <img
            src="${img}"
            style="
                width:50px;
                height:50px;
                object-fit:cover;
                margin:3px;
                border-radius:5px;
            ">
        `).join("");

}

