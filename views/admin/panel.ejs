    <strong id="sbStoreName">ShopZone</strong>
  </div>
</nav>

<!-- ═══ MAIN CONTENT ═══ -->
<main class="main" id="mainContent">
  <!-- Pages rendered here -->
</main>

</div><!-- /body-wrap -->

<!-- ═══ DELETE CONFIRM MODAL ═══ -->
<div class="modal-overlay" id="delModal">
  <div class="modal">
    <h3>⚠️ Confirm Delete</h3>
    <p id="delModalMsg" style="font-size:14px;color:#333;margin-bottom:8px;"></p>
    <p style="font-size:12px;color:#dc2626;">This action cannot be undone.</p>
    <div class="modal-actions">
      <button class="btn btn-outline" onclick="closeModal('delModal')">Cancel</button>
      <button class="btn btn-del" id="delModalConfirm">Delete</button>
    </div>
  </div>
</div>

<!-- ═══ PRODUCT DETAIL MODAL ═══ -->
<div class="modal-overlay" id="viewModal">
  <div class="modal" style="max-width:600px;">
    <h3 id="viewModalTitle">Product Details</h3>
    <div id="viewModalBody" style="font-size:13px;max-height:60vh;overflow-y:auto;"></div>
    <div class="modal-actions">
      <button class="btn btn-outline" onclick="closeModal('viewModal')">Close</button>
    </div>
  </div>
</div>

<script>
function copyProductUrl(encryptedId, btn) {
    const url = `${window.location.origin}/product?id=${encryptedId}`;

    navigator.clipboard.writeText(url).then(() => {
        const text = btn.querySelector(".btn-text");

        text.textContent = "Copied ✓";
        btn.disabled = true;

        setTimeout(() => {
            text.textContent = "Copy URL";
            btn.disabled = false;
        }, 2000);
    }).catch(() => {
        alert("Failed to copy URL");
    });
}
'use strict';
// ════════════════════════════════════════════════════════
// STATE
// ════════════════════════════════════════════════════════
let ALL_PRODS = [], ALL_CATS = [], ALL_REVS = [];
let META = { categories: [], brands: [] };
let CFG = {};
let RATING_VAL = 5;
let CURRENT_PAGE = 'dashboard';
let DELETE_CALLBACK = null;

// ════════════════════════════════════════════════════════
// SIDEBAR / NAVIGATION
// ════════════════════════════════════════════════════════
function toggleSidebar() {
  document.getElementById('sidebar').classList.toggle('open');
  document.getElementById('overlay').classList.toggle('open');
}

function navTo(page, closeSidebar = true) {
  CURRENT_PAGE = page;
  // Update active nav link
  document.querySelectorAll('.sidebar-link').forEach(l => l.classList.remove('active'));
  const navEl = document.getElementById('nav-' + page);
  if (navEl) navEl.classList.add('active');
  // Close sidebar on mobile
  if (closeSidebar && window.innerWidth <= 768) {
    document.getElementById('sidebar').classList.remove('open');
    document.getElementById('overlay').classList.remove('open');
  }
  // Render page
  renderPage(page);
}

function renderPage(page) {
  const main = document.getElementById('mainContent');
  switch(page) {
    case 'dashboard':    renderDashboard(); break;
    case 'products':     renderProducts(); break;
    case 'add-product':  renderAddProduct(EDIT_PRODUCT); break;
    case 'categories':   renderCategories(); break;
    case 'reviews':      renderReviews(); break;
    case 'payment':      renderPayment(); break;
    case 'bank':         renderBank(); break;
    case 'store':        renderStore(); break;
    default:             main.innerHTML = '<p>Page not found</p>';
  }
}

// ════════════════════════════════════════════════════════
// API HELPERS
// ════════════════════════════════════════════════════════
async function api(url, opts = {}) {
  try {
    const res = await fetch(url, opts);
    return await res.json();
  } catch(e) {
    return { success: false, error: e.message };
  }
}

// ════════════════════════════════════════════════════════
// MODAL HELPERS
// ════════════════════════════════════════════════════════
function openModal(id) { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }

function confirmDelete(msg, cb) {
  document.getElementById('delModalMsg').textContent = msg;
  DELETE_CALLBACK = cb;
  document.getElementById('delModalConfirm').onclick = () => { closeModal('delModal'); cb(); };
  openModal('delModal');
}

// ════════════════════════════════════════════════════════
// MESSAGES
// ════════════════════════════════════════════════════════
function showMsg(id, msg, type = 'success') {
  const cls = { success: 'msg-success', error: 'msg-error', info: 'msg-info', warn: 'msg-warn' };
  const icon = { success: '✓', error: '✗', info: 'ℹ', warn: '⚠' };
  const el = document.getElementById(id);
  if (!el) return;
  el.innerHTML = `<div class="msg ${cls[type]}">${icon[type]} ${msg}</div>`;
  setTimeout(() => { if(el) el.innerHTML = ''; }, 3500);
}

// ════════════════════════════════════════════════════════
// LOAD INITIAL DATA
// ════════════════════════════════════════════════════════
async function loadAll() {
  // Products
  const pd = await api('/admin/api/products');
  ALL_PRODS = pd.products || [];

  // Meta
  const md = await api('/admin/api/meta');
  META = md || { categories: [], brands: [] };

  // Reviews
  const rd = await api('/admin/api/reviews');
  ALL_REVS = rd.reviews || [];

  // Config
  const cd = await api('/admin/api/config');
  CFG = {};
  (cd.configs || []).forEach(c => CFG[c.config_key] = c.config_value);

  // Build categories from products
  const catSet = {};
  ALL_PRODS.forEach(p => { catSet[p.category] = (catSet[p.category] || 0) + 1; });
  ALL_CATS = Object.entries(catSet).map(([name, count]) => ({ name, count }));

  // Update sidebar badges
  document.getElementById('sb-prod-count').textContent = ALL_PRODS.length;
  document.getElementById('sb-cat-count').textContent = ALL_CATS.length;
  document.getElementById('sb-rev-count').textContent = ALL_REVS.length;

  // Store name
  const sn = CFG.store_name || 'ShopZone';
  document.getElementById('sbStoreName').textContent = sn;
  document.getElementById('topStoreName').textContent = sn;
  document.getElementById('sidebarStoreInfo').querySelector('strong').textContent = sn;
}

// ════════════════════════════════════════════════════════
// DASHBOARD
// ════════════════════════════════════════════════════════
function renderDashboard() {
  const lowStock = ALL_PRODS.filter(p => p.stock_quantity < 10 && p.stock_quantity > 0);
  const outStock = ALL_PRODS.filter(p => p.stock_quantity === 0);
  const featured = ALL_PRODS.filter(p => p.is_featured);
  const totalValue = ALL_PRODS.reduce((s, p) => s + parseFloat(p.price) * p.stock_quantity, 0);

  document.getElementById('mainContent').innerHTML = `
  <div class="breadcrumb">Admin / <span>Dashboard</span></div>
  <div class="page-header"><h1>📊 Dashboard</h1></div>

  <div class="stats">
