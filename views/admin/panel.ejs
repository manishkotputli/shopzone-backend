function renderCategories() {
  document.getElementById('mainContent').innerHTML = `
  <div class="breadcrumb">Admin / <span>Categories</span></div>
  <div class="page-header">
    <h1>🗂️ Categories</h1>
  </div>

  <div class="card" style="padding:0;">
    <div class="tbl-wrap">
      <table>
        <thead><tr><th>Category Name</th><th>Products</th><th>Sub-Categories</th><th>Top Brands</th><th>Avg Price</th><th>Actions</th></tr></thead>
        <tbody id="catTb"></tbody>
      </table>
    </div>
  </div>

  <div id="addCatForm" style="display:none;" class="card">
    <h2 id="catFormTitle">➕ Add Category</h2>
    <div id="catMsg"></div>
    <div class="grid2">
      <div class="fg"><label>Category Name *</label><input id="catName" placeholder="e.g. Electronics"></div>
      <div class="fg"><label>Parent Category (optional)</label><input id="catParent" placeholder="Leave blank for top-level"></div>
      <div class="fg full"><label>Description</label><textarea id="catDesc" rows="2" placeholder="Short category description..."></textarea></div>
    </div>
    <div class="form-actions">
      <button class="btn btn-primary" onclick="saveCategory()">💾 Save Category</button>
      <button class="btn btn-outline" onclick="document.getElementById('addCatForm').style.display='none'">Cancel</button>
    </div>
  </div>
  `;
  renderCatTable();
}

function renderCatTable() {
  const rows = ALL_CATS.map(c => {
    const prods = ALL_PRODS.filter(p => p.category === c.name);
    const brands = [...new Set(prods.map(p=>p.brand).filter(Boolean))].slice(0,3);
    const subCats = [...new Set(prods.map(p=>p.sub_category).filter(Boolean))].slice(0,3);
    const avgPrice = prods.length ? Math.round(prods.reduce((s,p)=>s+parseFloat(p.price),0)/prods.length) : 0;
    return `<tr>
      <td><strong style="font-size:13px;">📁 ${c.name}</strong></td>
      <td><span class="pill pill-blue">${prods.length} products</span></td>
      <td>${subCats.length?subCats.map(s=>`<span class="pill pill-gray" style="margin:1px;">${s}</span>`).join(''):'<span style="color:#999;">—</span>'}</td>
      <td>${brands.length?brands.map(b=>`<span class="pill pill-orange" style="margin:1px;">${b}</span>`).join(''):'—'}</td>
      <td>${avgPrice?'₹'+avgPrice.toLocaleString('en-IN'):'—'}</td>
      <td>
        <button class="btn btn-view btn-sm" onclick="viewCategoryProducts('${c.name}')">👁 Products</button>
        <button class="btn btn-edit btn-sm" onclick="editCategory('${c.name}')">✏️ Edit</button>
        <button class="btn btn-del btn-sm" onclick="deleteCategory('${c.name}',${prods.length})">🗑</button>
      </td>
    </tr>`;
  });
  document.getElementById('catTb').innerHTML = rows.length ? rows.join('') : '<tr class="empty-row"><td colspan="6">No categories found. Add products first.</td></tr>';
}

function openAddCat() {
  document.getElementById('addCatForm').style.display = 'block';
  document.getElementById('catFormTitle').textContent = '➕ Add Category';
  document.getElementById('catName').value = '';
  document.getElementById('catParent').value = '';
  document.getElementById('catDesc').value = '';
  window.scrollTo({ top: document.getElementById('addCatForm').offsetTop - 80, behavior: 'smooth' });
}
function editCategory(name) {
  document.getElementById('addCatForm').style.display = 'block';
  document.getElementById('catFormTitle').textContent = '✏️ Edit Category: ' + name;
  document.getElementById('catName').value = name;
  window.scrollTo({ top: document.getElementById('addCatForm').offsetTop - 80, behavior: 'smooth' });
}
function saveCategory() {
  const n = document.getElementById('catName').value.trim();
  if (!n) { showMsg('catMsg','Category name is required!','error'); return; }
  showMsg('catMsg','Category saved! Products in this category will be updated when you edit them.','success');
  document.getElementById('addCatForm').style.display = 'none';
}
function deleteCategory(name, count) {
  if (count > 0) {
    confirmDelete(`Category "${name}" has ${count} products. Deleting will not remove products but they won't belong to any category.`, () => {
      showMsg('catMsg','Category removed!','success');
      renderCatTable();
    });
  } else {
    confirmDelete(`Delete category "${name}"?`, () => { renderCatTable(); });
  }
}
function viewCategoryProducts(cat) {
  navTo('products', false);
  setTimeout(() => {
    const el = document.getElementById('catF');
    if (el) { el.value = cat; filterTable(); }
  }, 100);
}

