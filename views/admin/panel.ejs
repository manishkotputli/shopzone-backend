async function uploadQR(inp){
  if(!inp.files[0]) return;
  const fd=new FormData(); fd.append('qr',inp.files[0]);
  const d=await api('/admin/api/config/qr-upload',{method:'POST',body:fd});
  if(d.success){ CFG.qr_image=d.url; document.getElementById('qrPrev').innerHTML=`<img src="${d.url}">`; showMsg('payMsg','✅ QR uploaded successfully!','success'); }
  else showMsg('payMsg','❌ Upload failed: '+d.error,'error');
}
async function removeQR(){
  await api('/admin/api/config',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({qr_image:''})});
  CFG.qr_image=''; renderPayment(); showMsg('payMsg','QR removed','success');
}

